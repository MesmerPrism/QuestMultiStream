<Window x:Class="QuestMultiStream.App.CastControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Quest Cast Controls"
        Width="1460"
        Height="940"
        MinWidth="720"
        MinHeight="460"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Foreground="{StaticResource InkBrush}">
    <Grid x:Name="RootChrome"
          SnapsToDevicePixels="True">
        <Border Margin="2"
                CornerRadius="12"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                Background="Transparent"
                IsHitTestVisible="False" />

        <Grid Margin="2"
              IsHitTestVisible="False">
            <Border Height="1"
                    Margin="34,8,34,0"
                    VerticalAlignment="Top"
                    Background="{StaticResource LineBrush}"
                    Opacity="0.7" />
            <Border Height="1"
                    Margin="34,0,34,8"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource LineBrush}"
                    Opacity="0.7" />
            <Border Width="1"
                    Margin="8,34,0,34"
                    HorizontalAlignment="Left"
                    Background="{StaticResource LineBrush}"
                    Opacity="0.7" />
            <Border Width="1"
                    Margin="0,34,8,34"
                    HorizontalAlignment="Right"
                    Background="{StaticResource LineBrush}"
                    Opacity="0.7" />

            <Border Width="24"
                    Height="3"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="24"
                    Margin="18,18,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />

            <Border Width="24"
                    Height="3"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="24"
                    Margin="0,18,18,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />

            <Border Width="24"
                    Height="3"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="24"
                    Margin="18,0,0,18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />

            <Border Width="24"
                    Height="3"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />
            <Border Width="3"
                    Height="24"
                    Margin="0,0,18,18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2" />
        </Grid>

        <Border x:Name="CompositeBackdrop"
                Margin="2"
                CornerRadius="12"
                Background="#FF000000"
                Visibility="Collapsed"
                IsHitTestVisible="False" />

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderChrome"
                    Grid.Row="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="14,12"
                    PreviewMouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0" />
                            <TextBlock Text="{Binding ProximityStatusText}"
                                       Style="{StaticResource MicroCaptionStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding SessionDetailText}"
                                   Style="{StaticResource MicroCaptionStyle}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="MinimizeWindowButton"
                                    Width="34"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    Padding="0"
                                    Content="&#x2013;"
                                    ToolTip="Minimize cast window"
                                    Click="OnMinimizeWindowClicked" />
                            <Button x:Name="ToggleMaximizeWindowButton"
                                    Width="34"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    Padding="0"
                                    Content="&#x25A1;"
                                    ToolTip="Toggle full size"
                                    Click="OnToggleMaximizeWindowClicked" />
                            <Button x:Name="CloseWindowButton"
                                    Width="34"
                                    Height="30"
                                    Padding="0"
                                    Content="&#x2715;"
                                    ToolTip="Close cast"
                                    Click="OnCloseWindowClicked" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CaptureTargetMenuButton"
                                Content="{Binding SelectedCaptureTargetText}"
                                IsEnabled="{Binding CanEditCaptureTarget}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                Click="OnCaptureTargetMenuButtonClicked"
                                ToolTip="{Binding CaptureTargetHintText}"
                                HorizontalContentAlignment="Left"
                                MinWidth="320"
                                Margin="0" />
                        <Button Grid.Column="2"
                                x:Name="PinButton"
                                Content="{Binding CastWindowPinText}"
                                Command="{Binding ToggleCastWindowPinCommand}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                ToolTip="{Binding CastWindowPinHintText}"
                                MinWidth="104"
                                Margin="0" />
                        <Button Grid.Column="4"
                                x:Name="ProximityButton"
                                Content="{Binding ToggleProximityText}"
                                Command="{Binding ToggleProximityCommand}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                ToolTip="{Binding ToggleProximityHintText}"
                                MinWidth="126"
                                Margin="0" />
                        <Button Grid.Column="6"
                                x:Name="StopButton"
                                Content="Stop"
                                Command="{Binding StopCastCommand}"
                                PreviewMouseLeftButtonDown="OnInteractiveControlPreviewMouseLeftButtonDown"
                                MinWidth="74"
                                Margin="0" />
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="CompositeViewportHost"
                    Grid.Row="2"
                    CornerRadius="10"
                    Background="#FF000000"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    ClipToBounds="True">
                <Grid>
                    <Image x:Name="CompositePreviewImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="CompositeStatusText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource MicroCaptionStyle}"
                               Text="Composite preview is warming up."
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>

        <primitives:Thumb x:Name="LeftGrip"
                          Width="8"
                          HorizontalAlignment="Left"
                          Cursor="SizeWE"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="RightGrip"
                          Width="8"
                          HorizontalAlignment="Right"
                          Cursor="SizeWE"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="TopGrip"
                          Height="8"
                          VerticalAlignment="Top"
                          Cursor="SizeNS"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomGrip"
                          Height="8"
                          VerticalAlignment="Bottom"
                          Cursor="SizeNS"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="TopLeftGrip"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Cursor="SizeNWSE"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="TopRightGrip"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Cursor="SizeNESW"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomLeftGrip"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Bottom"
                          Cursor="SizeNESW"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
        <primitives:Thumb x:Name="BottomRightGrip"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Cursor="SizeNWSE"
                          Background="Transparent"
                          DragStarted="OnResizeGripDragStarted"
                          DragDelta="OnResizeGripDragDelta"
                          DragCompleted="OnResizeGripDragCompleted" />
    </Grid>
</Window>
